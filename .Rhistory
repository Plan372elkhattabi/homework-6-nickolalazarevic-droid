install.packages("tidycensus")
library(tidycensus)
census_api_key("6157b37bc4f68db9c8e3043c96b2714ff30e2564")
census_api_key("6157b37bc4f68db9c8e3043c96b2714ff30e2564", install = TRUE)
library(tidyverse)
load_variables(2020, data = "acs5")
varibale_list <- load_variables(2020, data = "acs5")
View(varibale_list)
get_acs(geography = "block group",
state = "NC"
variables = "B02001_001")
test_acs <- get_acs(geography = "block group",
state = "NC"
variables = "B02001_001")
test_acs <- get_acs(geography = "block group",
state = "NC",
variables = "B02001_001")
test_acs <- get_acs(geography = "block group",
state = "NC",
variables = starts_with("B02001_001"))
test_acs <- get_acs(geography = "block group",
state = "NC",
variables = c("B02001_001","B02001_002"))
View(test_acs)
poverty_data <- get_acs(geography = "county",
variables = c(total_pop = "B17001_001",
poverty_pop = "B17001_002"),
survey = "acs5")
View(poverty_data)
install.packages("tigris")
load(tigris)
library(tigris)
counties(state = NULL, cb = FALSE, resolution = "500k", year = NULL)
counties(state = NC, cb = FALSE, resolution = "500k", year = NULL)
counties(state = "NC", cb = FALSE, resolution = "500k", year = NULL)
counties_NC <- counties(state = "NC", cb = FALSE, resolution = "500k", year = NULL)
View(counties_NC)
poverty_wide <- poverty_data %>%
select(GEOID, NAME, variable, estimate) %>%
pivot_wider(names_from = variable, values_from = estimate)
poverty_wide <- poverty_wide %>%
rename(
total_pop = B17001_001,
poverty_pop = B17001_002
)
View(poverty_wide)
poverty_wide <- poverty_wide %>%
mutate(poverty_rate = poverty_pop / total_pop)
counties_merged <- counties_NC %>%
left_join(poverty_wide, by = "GEOID")
ggplot(counties_merged) +
geom_sf(aes(fill = poverty_rate)) +
scale_fill_viridis_c() +
labs(
title = "Poverty Rate by County in North Carolina",
fill = "Poverty Rate"
) +
theme_minimal()
