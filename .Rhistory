library(tidyverse)
# Read the raw tree data (adjust path/filename if needed)
data = read_csv("TS3_Raw_tree_data.csv")
head(data)
# ---- Question 1: Sample sizes by state ----
# Check that every City value matches our pattern
all(str_detect(data$City, "^.+, [:upper:]{2}$"))
# See what str_match returns: total match + one column per capture group
str_match(data$City, "^(.+), ([:upper:]{2})$")
# Assign the captured groups to new columns
data[,c("city_name", "state")] = str_match(data$City, "^(.+), ([:upper:]{2})$")[,2:3]
head(data)
# Records per state
state_counts = data |>
group_by(state) |>
summarize(n = n()) |>
arrange(-n)
state_counts
# Bar plot
ggplot(state_counts, aes(x = state, y = n)) +
geom_col()
# ---- Question 2: Cities in NC and SC ----
# Filter the dataset down to NC and SC for the rest of the assignment
data = filter(data, state == "NC" | state == "SC")
# Cities in each state
data |>
group_by(state, city_name) |>
summarize(n = n()) |>
arrange(state, city_name)
# ---- Question 3: Genus with the largest average crown diameter ----
# Confirm the pattern matches
all(str_detect(data$ScientificName, "^[:alpha:]+ [:alpha:]+"))
# Extract the genus (everything before the first space)
data$genus = str_match(data$ScientificName, "^([:alpha:]+)")[,2]
head(data)
# Average crown diameter by genus
genus_crown = data |>
group_by(genus) |>
summarize(avg_crown = mean(`AvgCdia (m)`, na.rm = TRUE), n = n()) |>
arrange(-avg_crown)
genus_crown
# Genus with the largest average crown
head(genus_crown, 1)
# ---- Question 4: Tree age across genera ----
# Average age (and crown) by genus
genus_age = data |>
group_by(genus) |>
summarize(avg_age = mean(Age, na.rm = TRUE),
avg_crown = mean(`AvgCdia (m)`, na.rm = TRUE),
n = n()) |>
arrange(-avg_age)
genus_age
# Plot age vs crown diameter at the genus level
ggplot(genus_age, aes(x = avg_age, y = avg_crown)) +
geom_point()
